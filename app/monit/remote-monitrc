# WARNING: BEGIN FS/END FS and BEGIN S3/END S3 sets are controlled at run time by the main switch.
# It will enable/disable S3/FS scanners during MVS initialization
# It should not be removed or changed manually 
set init
# enable monitoring daemon to run every 60 sec

SET DAEMON 60 WITH START DELAY 120
set log /var/log/mvs/monit.log

# enable httpd support
set httpd 
    port 2812 
    allow admin:monit
    allow guest:guest read-only
    allow @admins
    allow @users read-only

# enable monitoring 

# Start cron
 check process cron MATCHING cron
   group system
   start program = "/etc/init.d/cron start" with timeout 60 seconds
   stop  program = "/etc/init.d/cron stop"
   depends on cron_rc

 check file cron_rc with path /etc/cron.d/multiav-cron
   group system
   if failed checksum then alert
   if failed permission 644 then alert
   if failed uid root then alert
   if failed gid root then alert

# alert if running close to OOM
# check system $HOST
#   if memory usage > 95% for 4 cycles then alert

check program check_scan_data with path '/app/scanners/functions/check_scan_data'
   group virus
   if status != 0 then alert
# BEGIN S3
   depends on S3multi-scanner
# END S3

# BEGIN FS
   depends on FSmulti-scanner
# END FS

# enable monitoring freshclam
check directory clamav_logs path /var/log/clamav
  if does not exist then exec "/bin/mkdir -p /var/log/clamav"

check process freshclam MATCHING freshclam
  group virus
  start program = "/usr/bin/freshclam -d -v --no-dns --config-file=/etc/clamav/freshclam.conf --pid=/var/run/clam.pid" with timeout 360 seconds
  depends on freshclam_bin
  depends on freshclam_rc
  depends on clamav_logs
  
check file clamavd_rc with path /etc/clamav/clamd.conf
  group virus
  if does not exist then alert
  if failed checksum then alert
  if failed permission 644 then alert
  if failed uid root then alert
  if failed gid root then alert

check file freshclam_bin with path /usr/bin/freshclam
  group virus
  if failed checksum then alert
  if failed permission 755 then alert
  if failed uid root then alert
  if failed gid root then alert

check file freshclam_rc with path /etc/clamav/freshclam.conf
  group virus
  if does not exist then alert
  if failed checksum then alert
  if failed permission 444 then alert

check file freshclam_bytecode with path /var/lib/clamav/bytecode.cvd
  group virus
  if does not exist then alert
  depends on freshclam

 # check if main.cvd  or main.cld is upto date 
 # this file is updated very infrequently 
 check program freshclam_main with path /app/clamav/check_main.sh
   if status != 0  then alert
   depends on freshclam
   depends on clamav_logs

# check if bytecode  is uptodate 
# this file is updated very infrequently 
# check program freshclam_bytecode_version with path /app/clamav/check_bytecode.sh
#   every "10-15 4-6 * * *"
#   if status != 0 then alert

# daily needs to be checked through a script since it's name flips 
# between cld and cvd
check program freshclam_daily with path /app/clamav/check_daily.sh
  group virus
  if status != 0 then alert
  depends on freshclam
  depends on clamav_logs

# enable monitoring clamav-daemon
check process clamav-daemon MATCHING clamd
  group virus
  start program = "/usr/sbin/clamd start" with timeout 60 seconds
  stop program = "/usr/sbin/clamd stop"
  restart program = "/usr/sbin/clamd restart" with timeout 60 seconds
  if failed unixsocket /var/run/clamav/clamd.ctl then restart
  depends on clamavd_bin
  depends on clamavd_rc
  depends on freshclam_main
  depends on freshclam_daily
  depends on freshclam_bytecode
  depends on clamav_logs
  
check file clamavd_bin with path /usr/sbin/clamd
  group virus
  if failed checksum then alert
  if failed permission 755 then alert
  if failed uid root then alert
  if failed gid root then alert


# create mcafee dir
check directory mcafee_logs  path /var/log/mcafee
  if does not exist then exec "/bin/mkdir -p /var/log/mcafee"

check file mcafee_bin with path /app/uvscan/updater.sh
  group virus
  if failed checksum then alert
  if failed permission 755 then alert
  if failed uid root then alert
  if failed gid root then alert

check file mcafee_db with path /app/uvscan/avvscan.dat
  group virus
# The first test below is highly unlikely to fail since mcafee updater depends on avvscan.dat to be present 
# so there will be one but most likely very old one (unfortunately, it's built into mcafee updater) .
# Therefore there is this second test which almost always 
# will fail and the update will take place.
  if does not exist then exec "/bin/bash -c '/app/uvscan/updater.sh  >> /var/log/mcafee/mcafee-updater.log 2>&1'" 
  if timestamp is older than 5 days then exec "/bin/bash -c '/app/uvscan/updater.sh  >> /var/log/mcafee/mcafee-updater.log 2>&1'"
  if failed uid root then alert
  if failed gid root then alert
  if timestamp is older than 5 days then alert
  depends on mcafee_bin
  depends on mcafee_logs

# BEGIN FS
# create input, output, infected directories for FSmulti-scanner
check directory scan_input path /var/scan/input
  if does not exist then exec "/bin/mkdir -p /var/scan/input"
check directory scan_output path /var/scan/output
  if does not exist then exec "/bin/mkdir -p /var/scan/output"
check directory scan_infected path /var/scan/infected
  if does not exist then exec "/bin/mkdir -p /var/scan/infected"

# enable monitoring scanner app
CHECK PROCESS FSmulti-scanner MATCHING 'multiav_fs_scanner*'
  group virus
  start program = "/bin/bash -c '/app/daemons/fs_daemon.sh start'"
  stop program = "/bin/bash -c '/app/daemons/fs_daemon.sh stop'"
  restart program = "/bin/bash -c '/app/daemons/fs_daemon.sh restart'"
  if 5 restarts within 10 cycles then alert
  depends on scan_input
  depends on scan_output
  depends on scan_infected
  depends on clamav-daemon
  depends on mcafee_db
# END FS
# BEGIN S3
CHECK PROCESS S3multi-scanner MATCHING 'multiav_s3_scanner*'
  start program = "/bin/bash -c '/app/daemons/s3_daemon.sh start'"
  stop program = "/bin/bash -c '/app/daemons/s3_daemon.sh stop'"
  restart program = "/bin/bash -c '/app/daemons/s3_daemon.sh restart'"
  if 5 restarts within 10 cycles then alert
  depends on clamav-daemon
  depends on mcafee_db
# END S3

